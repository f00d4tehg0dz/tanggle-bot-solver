# Tanggle Bot Solver Configuration
# Copy this file to .env and fill in your Tanggle account credentials. You can also configure VPN settings for automatic IP rotation on 403 blocks.
TANGGLE_EMAIL=your-email@example.com
TANGGLE_PASSWORD=your-password

# VPN rotation — set to true to enable automatic IP rotation on 403 blocks
VPN_ENABLED=false
# Provider: openvpn, pia, or nordvpn
VPN_PROVIDER=openvpn
# Directory with .ovpn files (only needed for openvpn provider)
VPN_DIR=./vpn